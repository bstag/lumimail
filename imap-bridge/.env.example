LUMIMAIL_API_URL=https://mail.yourdomain.com
IMAPS_PORT=993
SMTP_PORT=587
BRIDGE_HOST=0.0.0.0
TLS_KEY_PATH=/etc/ssl/private/bridge.key
TLS_CERT_PATH=/etc/ssl/certs/bridge.crt

# Development only: permits plaintext IMAP/SMTP, forces loopback binding,
# and defaults to ports 1143/1587. Never enable on a public host.
ALLOW_INSECURE_LOCALHOST=false
